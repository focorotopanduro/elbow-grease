{
  "name": "beitbuilding-website",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Beit Building Contractors LLC — official website (owned backup of beitbuilding.com)",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/build-blog-routes.mjs && node scripts/build-sitemap.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:preflight": "npm run lint && npm run audit:security && npm test && npm run check:nap",
    "audit:security": "node scripts/audit-security.mjs",
    "audit:prod-deps": "npm audit --omit=dev --audit-level=moderate",
    "audit:vercel": "node scripts/audit-vercel-release.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "audit:static": "node scripts/audit-static-release.mjs",
    "package:hostinger": "node scripts/package-hostinger.mjs",
    "release:vercel": "npm run audit:prod-deps && npm run verify:preflight && npm run build && npm run audit:vercel",
    "release:hostinger": "npm run verify:preflight && npm run build && npm run audit:static && npm run verify:release && npm run package:hostinger",
    "build:sitemap": "node scripts/build-sitemap.mjs",
    "build:blog-routes": "node scripts/build-blog-routes.mjs",
    "check:nap": "node scripts/nap-audit.mjs",
    "analytics:summary": "node scripts/analytics-summary.mjs",
    "lead:inbox": "node scripts/lead-inbox.mjs",
    "optimize-logos": "node scripts/optimize-logos.mjs",
    "export:scene": "node scripts/export-scene-elements.mjs",
    "export:scene:force": "node scripts/export-scene-elements.mjs --force",
    "export:scene:list": "node scripts/export-scene-elements.mjs --list",
    "export:scene:watch": "node scripts/export-scene-elements.mjs --watch",
    "lint": "eslint ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@mdx-js/rollup": "^3.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.0.2",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx-frontmatter": "^5.0.0",
    "sharp": "^0.34.5",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
