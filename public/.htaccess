# Apache/Hostinger production rules for the static Vite build.
# Upload the contents of dist/ into public_html; this file is copied there by Vite.

Options -Indexes -MultiViews

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Keep the deferred hurricane simulator from surfacing if an old URL is visited.
  RewriteRule ^hurricane-uplift(?:\.html)?$ /#contact [R=302,L,NE]

  # Hostinger static hosting cannot run Vercel API functions. Return a real
  # miss so the client falls through to Web3Forms/mailto instead of treating
  # index.html as a successful lead API response.
  RewriteRule ^api/ - [R=404,L]

  # Serve existing files and folders directly.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Vercel cleanUrls equivalent: /orlando-roofing -> /orlando-roofing.html.
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]

  # SPA fallback for unknown app routes.
  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set X-XSS-Protection "0"
  Header always set X-Permitted-Cross-Domain-Policies "none"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set Cross-Origin-Resource-Policy "same-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=(), autoplay=(self), fullscreen=(self), picture-in-picture=()"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://assets.calendly.com https://app.cal.com https://embed.cal.com; script-src-attr 'none'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://assets.calendly.com; font-src 'self' https://fonts.gstatic.com https://assets.calendly.com; img-src 'self' data: https://maps.gstatic.com https://maps.googleapis.com https://*.calendly.com https://*.cal.com; media-src 'self'; connect-src 'self' https://api.web3forms.com https://calendly.com https://*.calendly.com https://app.cal.com https://embed.cal.com; frame-src https://www.google.com https://maps.google.com https://calendly.com https://*.calendly.com https://app.cal.com https://embed.cal.com; worker-src 'self'; manifest-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self' mailto: https://api.web3forms.com; object-src 'none'; upgrade-insecure-requests"

  <FilesMatch "\.(?:html)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>

  <FilesMatch "\.(?:js|css|png|jpe?g|webp|svg|woff2?|ttf|otf|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "^(?:sw\.js|manifest\.webmanifest|robots\.txt|sitemap\.xml|security\.txt)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>
