# ─────────────────────────────────────────────────────────────────────────
# Beit Building Contractors website — environment variables
#
# All keys here are SAFE TO COMMIT (this file is a template). Real values
# go in `.env.local` (gitignored). Anything prefixed with VITE_ is exposed
# to the BROWSER bundle — do NOT put server secrets there.
# ─────────────────────────────────────────────────────────────────────────

# ─── FRONT-END (browser-visible, prefixed VITE_) ─────────────────────────

# Web3Forms — primary front-end email path. Get a free key at web3forms.com
# (no credit card, takes 2 minutes). Production traffic flows through this
# unless you switch primary to /api/leads (server-side email — see below).
#   1. Sign up at https://web3forms.com → confirm via email
#   2. Use sandravasquezcgc@gmail.com as the inbox during owner onboarding
#   3. Paste the access key here in your local `.env`
VITE_WEB3FORMS_KEY=your-access-key-here

# Optional mirror destination for the normalized contact-form payload.
# For local office testing, run `npm run lead:inbox` and set:
#   VITE_LEAD_ENDPOINT=http://127.0.0.1:8787/lead-intake
#   VITE_LEAD_ENDPOINT_TOKEN=
# Leave both blank in production.
VITE_LEAD_ENDPOINT=
VITE_LEAD_ENDPOINT_TOKEN=

# Business contact info (used in schema/footer/links)
VITE_BUSINESS_PHONE=+14079426459
VITE_BUSINESS_EMAIL=beitbuilding@gmail.com
VITE_BUSINESS_WHATSAPP=4079426459

# Optional Zoom/booking link for business clients. Leave blank until the
# production Zoom/Calendar URL is ready; the form can still record Zoom
# as the visitor's preferred follow-up channel.
VITE_ZOOM_URL=

# Optional: enable when running a local API proxy that serves /api/events
VITE_ENABLE_DEV_BEACONS=false

# Optional exact API origins beyond beitbuilding.com/www and the current
# Vercel deployment URL. Do not use wildcards.
# Example: ADDITIONAL_ALLOWED_ORIGINS=https://staging.beitbuilding.com
ADDITIONAL_ALLOWED_ORIGINS=


# ─── SERVER-SIDE (Vercel function env, NOT exposed to browser) ───────────

# /api/leads always tries to email the operations contact when one of the
# providers below is configured. Recipient defaults to mom's email when
# LEAD_NOTIFY_TO is unset — see api/_lib/email.ts DEFAULT_OPERATIONS_EMAIL.

# Recipient — the inbox that receives every new lead notification
# (rich HTML + plain-text email). Comma-separated for multiple. Set this
# in Vercel → Project → Settings → Environment Variables.
LEAD_NOTIFY_TO=sandravasquezcgc@gmail.com

# Optional CC list (also comma-separated). Useful for adding a backup
# operator or a shared inbox during onboarding.
LEAD_NOTIFY_CC=

# Default From address shown in the recipient's inbox. Resend / SendGrid
# require the domain to be verified in their dashboard before sending.
EMAIL_FROM=Beit Building Leads <leads@beitbuilding.com>

# ─── Email providers (configure ONE; the rest are fallbacks) ──────────

# Resend (recommended) — modern API, 100/day free tier, ~5min DNS setup
# https://resend.com → Sign up → Add domain (beitbuilding.com) → API Keys
RESEND_API_KEY=

# SendGrid alternative — Twilio-owned, mature, 100/day free tier
# https://sendgrid.com → Settings → API Keys → Create API Key
SENDGRID_API_KEY=

# MailChannels alternative — free with Cloudflare Workers, key required
# elsewhere. Most useful as a Resend backup.
MAILCHANNELS_API_KEY=

# Generic webhook fallback — receives a JSON payload of the email body
# so you can pipe leads into Make / Zapier / n8n / your own collector.
EMAIL_WEBHOOK_URL=

# ─── Webhook destinations (also opt-in) ──────────────────────────────

# Slack incoming webhook for the team channel. Each lead lands as a
# Block Kit message with a tap-to-call link. See docs/lead-routing.md.
SLACK_LEADS_WEBHOOK=

# Discord webhook for a server channel. Each lead lands as a brand-gold
# embed. See docs/lead-routing.md.
DISCORD_LEADS_WEBHOOK=

# ─── Vercel KV (storage) ─────────────────────────────────────────────

# Auto-injected by Vercel when you Create Database → KV in the project
# storage tab. Lead records persist for 90 days (auto-evicted by TTL +
# the daily cron at /api/cron/purge-leads). If unset, the API gracefully
# degrades — leads still email + log, just no persistent archive.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── Cron secret (review-request automation) ──────────────────────────

# Used by Vercel Cron to authenticate scheduled invocations of
# /api/cron/* paths. Generate with `openssl rand -hex 32`.
CRON_SECRET=
